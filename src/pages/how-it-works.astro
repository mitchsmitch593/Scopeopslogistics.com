---
import CTABanner from '@/components/CTABanner.astro';
import Hero from '@/components/Hero.astro';
import ProcessSteps from '@/components/ProcessSteps.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { processSteps } from '@/data/process';
import { siteConfig } from '@/data/site';

const timelineItems = [
  {
    label: 'Hour 0',
    title: 'Request submitted',
    description: 'Send the task, volume, timeline, and location through the quote form.',
  },
  {
    label: 'Next business day',
    title: 'Scope review begins',
    description: 'ScopeOps reviews the workload and follows up if details are needed.',
  },
  {
    label: 'After scope confirmation',
    title: 'Project quote delivered',
    description: 'You receive pricing tied to the project requirements and operating conditions.',
  },
  {
    label: 'Scheduled window',
    title: 'Team deployed',
    description: 'Work begins once timing, access, and site expectations are aligned.',
  },
];
---

<BaseLayout
  title="How It Works"
  description="Learn how the warehouse quote and work process moves from scope to completion without disrupting your team."
>
  <Hero
    eyebrow="How it works"
    title="The fast track to a clear floor."
    description="No long hiring cycles. No administrative drag. ScopeOps streamlines quoting and deployment so warehouse bottlenecks can move from problem to action quickly."
    primaryCta={{ label: 'Request a Project Quote', href: '/request-a-quote' }}
    secondaryCta={{ label: 'Contact Us', href: '/contact' }}
    compact
    panelTitle="Zero administrative drag"
    panelBody="Most teams already know what is stuck. ScopeOps helps turn that pressure point into a reviewed scope, project quote, and execution path."
  />

  <Section>
    <SectionIntro
      eyebrow="The process"
      title="High-accountability support for busy warehouse managers."
      description="The goal is to remove friction: you share the scope, ScopeOps reviews the workload, and the project moves forward without turning into a long labor search."
    />
    <div class="mt-10">
      <ProcessSteps steps={processSteps} />
    </div>
  </Section>

  <Section surface="mist">
    <div class="card-dark p-8 lg:p-10">
      <p class="eyebrow !border-white/15 !bg-white/5 !text-accent-400">Supervisor-centric support</p>
      <h2 class="mt-6 font-serif text-3xl font-medium tracking-tight text-balance sm:text-4xl">
        Less babysitting for your supervisors.
      </h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-white/80">
        The biggest cost of traditional labor is often the time your supervisors spend directing it. ScopeOps structures
        projects around coordinated execution, throughput, and safety alignment so your managers can stay focused on daily operations.
      </p>
    </div>
  </Section>

  <Section>
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <SectionIntro
        eyebrow="Quote transparency"
        title="Project pricing is designed to reduce surprises."
        description="Instead of an open-ended hourly meter, ScopeOps reviews the workload up front and prices around the task, expected volume, timing, and site requirements."
      />
      <div class="card-surface p-8">
        <ul class="space-y-4">
          {siteConfig.quoteFactors.map((factor) => (
            <li class="flex gap-3 border-b border-charcoal-100 pb-4 last:border-none last:pb-0">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
              <span class="text-sm leading-7 text-charcoal-900">{factor}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 rounded-2xl bg-mist-100 p-5 text-sm font-semibold leading-7 text-brand-950">
          The price reflects the project information provided. If the scope changes, the quote can be reviewed before work proceeds.
        </p>
      </div>
    </div>
  </Section>

  <Section surface="mist">
    <SectionIntro
      eyebrow="Rapid response"
      title="A practical timeline for urgent warehouse work."
      description="Exact timing depends on scope, location, access, and facility requirements, but the process is built to move quickly once the work is defined."
    />
    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {timelineItems.map((item) => (
        <article class="card-surface p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">{item.label}</p>
          <h3 class="mt-4 text-xl font-semibold tracking-tight text-brand-950">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-charcoal-800">{item.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section>
    <CTABanner
      eyebrow="Stop the administrative headache"
      title="Get a quote today."
      description={`Send the workload, volume, and timeline. ScopeOps will review the request and respond within one business day for most quote requests. Call ${siteConfig.contactPhone} if the bottleneck is urgent.`}
      primaryLabel="Request a Project Quote"
    />
  </Section>
</BaseLayout>
