---
import CTABanner from '@/components/CTABanner.astro';
import Hero from '@/components/Hero.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';
---

<BaseLayout
  title="Warehouse Services"
  description="Container unloading, fulfillment overflow, kitting, reverse logistics, rework, and scoped warehouse support priced by the job."
>
  <Hero
    eyebrow="Services"
    title="Warehouse services for overflow, backlogs, and special projects."
    description="Use ScopeOps when the work is specific, the pressure is real, and your internal team needs added capacity without a traditional temp-labor arrangement."
    primaryCta={{ label: 'Request a Quote', href: '/request-a-quote' }}
    secondaryCta={{ label: 'How It Works', href: '/how-it-works' }}
    compact
    panelTitle="Built around execution"
    panelBody="The conversation starts with the work: what it is, how much there is, where it is happening, and when it needs attention."
  />

  <Section>
    <SectionIntro
      eyebrow="Service lines"
      title="Choose the service that matches the warehouse bottleneck."
      description="Each service is written around real operational pressure: inbound freight, outbound volume, project work, returns, and cleanup."
    />
    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {services.map((service) => <ServiceCard service={service} />)}
    </div>
  </Section>

  <Section surface="mist">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Use this model when</p>
        <p class="mt-4 text-sm leading-7 text-charcoal-900">
          The task is defined, time-sensitive, and difficult to absorb with the team already on the floor.
        </p>
      </div>
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Quoted by the job</p>
        <p class="mt-4 text-sm leading-7 text-charcoal-900">
          Pricing is tied to the workload and requirements, not simply the number of labor hours requested.
        </p>
      </div>
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Best fit for</p>
        <p class="mt-4 text-sm leading-7 text-charcoal-900">
          Operators who need a practical answer to a capacity problem and a simple way to explain the spend.
        </p>
      </div>
    </div>
  </Section>

  <Section>
    <CTABanner
      title="Need help with a specific warehouse job?"
      description="Send the type of work, estimated volume, timeline, and location. The clearer the scope, the faster the quote process moves."
    />
  </Section>
</BaseLayout>
