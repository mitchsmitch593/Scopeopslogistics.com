---
import CTABanner from '@/components/CTABanner.astro';
import Hero from '@/components/Hero.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';

const serviceBySlug = Object.fromEntries(services.map((service) => [service.slug, service]));
const serviceGroups = [
  {
    eyebrow: 'Inbound & velocity',
    title: 'The dock clearers',
    description:
      'Use these services when inbound freight, yard congestion, or returns volume starts disrupting warehouse flow.',
    items: ['container-unloading', 'reverse-logistics'],
  },
  {
    eyebrow: 'Outbound & scalability',
    title: 'The ship-time protectors',
    description:
      'Use these services when order volume, promotional spikes, or outbound backlog starts threatening customer commitments.',
    items: ['pick-and-pack-overflow', 'fulfillment-support', 'peak-and-surge-support'],
  },
  {
    eyebrow: 'Specialty & cleanup',
    title: 'The problem solvers',
    description:
      'Use these services for labor-heavy projects, rework, overdue tasks, and the work your team keeps pushing to later.',
    items: ['kitting-and-assembly', 'rework-projects', 'inventory-backlog-and-odd-projects'],
  },
];
---

<BaseLayout
  title="Warehouse Services"
  description="Container unloading, fulfillment overflow, kitting, reverse logistics, rework, and scoped warehouse support priced by the job."
>
  <Hero
    eyebrow="Services"
    title="Execution-ready teams for your toughest warehouse bottlenecks."
    description="ScopeOps does more than provide labor. We support finished warehouse projects, from container surges to long-running backlogs, with coordinated teams and project-based execution."
    primaryCta={{ label: 'Request a Project Quote', href: '/request-a-quote' }}
    secondaryCta={{ label: 'How It Works', href: '/how-it-works' }}
    compact
    panelTitle="Built around execution"
    panelBody="The conversation starts with the bottleneck: what is stuck, how much volume is involved, and when the work needs to move."
  />

  <Section>
    <SectionIntro
      eyebrow="Find the fire"
      title="Service categories organized by the problem on your floor."
      description="Instead of sorting through a generic list, start with the warehouse bottleneck that is creating the most pressure."
    />
    <div class="mt-12 space-y-14">
      {serviceGroups.map((group) => (
        <section aria-labelledby={`${group.eyebrow.toLowerCase().replaceAll(' ', '-')}-heading`}>
          <div class="mb-6 rounded-[1.75rem] border border-charcoal-100 bg-brand-950 px-6 py-5 text-white shadow-[var(--shadow-panel)]">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-400">{group.eyebrow}</p>
            <h2 id={`${group.eyebrow.toLowerCase().replaceAll(' ', '-')}-heading`} class="mt-2 font-serif text-3xl font-medium tracking-tight">
              {group.title}
            </h2>
            <p class="mt-3 max-w-3xl text-sm leading-7 text-white/75">{group.description}</p>
          </div>
          <div class="grid gap-6 lg:grid-cols-2">
            {group.items.map((slug) => <ServiceCard service={serviceBySlug[slug]} />)}
          </div>
        </section>
      ))}
    </div>
  </Section>

  <Section surface="mist">
    <SectionIntro
      eyebrow="ScopeOps standard"
      title="The standards we bring to your floor."
      description="The goal is to make project support easier to buy, easier to manage, and easier to explain internally."
    />
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Managed execution</p>
        <p class="mt-4 text-sm leading-7 text-charcoal-900">
          ScopeOps coordinates the work around the project so your supervisors are not left to manage every detail.
        </p>
      </div>
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Project-based pricing</p>
        <p class="mt-4 text-sm leading-7 text-charcoal-900">
          Pricing is tied to the task, volume, and timeline instead of open-ended hourly billing.
        </p>
      </div>
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Safety alignment</p>
        <p class="mt-4 text-sm leading-7 text-charcoal-900">
          Work is planned around your facility standards, operating rules, and site requirements.
        </p>
      </div>
    </div>
  </Section>

  <Section>
    <CTABanner
      title="Get your floor back."
      description="Stop letting backlogs and surges dictate your warehouse flow. Send ScopeOps your scope, volume, and timeline for a project-based quote."
      primaryLabel="Solve My Bottleneck"
    />
  </Section>
</BaseLayout>
