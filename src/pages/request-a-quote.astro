---
import Hero from '@/components/Hero.astro';
import QuoteForm from '@/components/QuoteForm.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
---

<BaseLayout
  title="Request a Quote"
  description="Request a warehouse operations quote for container unloading, fulfillment overflow, kitting, reverse logistics, rework, and special projects."
>
  <Hero
    eyebrow="Request a quote"
    title="Request a quote for a warehouse job."
    description="Share the task, volume, timeline, and location. ScopeOps reviews the information and follows up with the next step."
    primaryCta={{ label: 'Start Your Request', href: '#quote-form' }}
    secondaryCta={{ label: 'How It Works', href: '/how-it-works' }}
    compact
    panelTitle="What helps us respond faster"
    panelBody="Useful details include work type, estimated units, dock or facility constraints, urgency, and whether the need is one-time or recurring."
  />

  <Section id="quote-form">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_22rem]">
      <div>
        <SectionIntro
          eyebrow="Quote request"
          title="Start with the warehouse task that needs attention first."
          description="The form is built for project-based warehouse work, not open-ended labor requests. Include the details you already know."
        />
        <div class="mt-8">
          <QuoteForm />
        </div>
        <div class="mt-8 grid gap-6 lg:grid-cols-3">
          <div class="rounded-[1.5rem] border border-charcoal-100 bg-mist-100 px-6 py-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">What happens next</p>
            <p class="mt-3 text-sm leading-7 text-charcoal-900">We review the job details and make sure there is enough information to scope the work correctly.</p>
          </div>
          <div class="rounded-[1.5rem] border border-charcoal-100 bg-mist-100 px-6 py-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Follow-up if needed</p>
            <p class="mt-3 text-sm leading-7 text-charcoal-900">If something affects timing, volume, or site conditions, we may ask a few quick follow-up questions.</p>
          </div>
          <div class="rounded-[1.5rem] border border-charcoal-100 bg-mist-100 px-6 py-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Quote and next step</p>
            <p class="mt-3 text-sm leading-7 text-charcoal-900">Once the review is complete, you receive pricing and the recommended path for moving the work forward.</p>
          </div>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="card-surface p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Quotes are based on</p>
          <ul class="mt-5 space-y-4">
            {siteConfig.quoteFactors.map((factor) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
                <span class="text-sm leading-7 text-charcoal-900">{factor}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="card-dark p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-400">Need help right away?</p>
          <p class="mt-4 text-sm leading-7 text-white/80">
            If the workload is urgent, email {siteConfig.contactEmail} or call {siteConfig.contactPhone}. A quick conversation can confirm whether this is a fit and what to do next.
          </p>
        </div>

        <div class="card-surface p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">A strong request usually includes</p>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-charcoal-900">
            <li>What the work is</li>
            <li>Estimated volume or unit count</li>
            <li>Where the work is happening</li>
            <li>When you need it handled</li>
            <li>Anything that affects scope or timing</li>
          </ul>
        </div>

        <div class="card-surface p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Best for</p>
          <p class="mt-4 text-sm leading-7 text-charcoal-900">
            Defined warehouse jobs, overflow order volume, backlog cleanup, unloading, kitting, returns work, and special projects.
          </p>
          <p class="mt-4 text-sm leading-7 text-charcoal-800">
            Not designed for open-ended hourly labor requests with no clear warehouse scope.
          </p>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>
