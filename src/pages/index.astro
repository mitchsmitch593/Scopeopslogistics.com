---
import CTABanner from '@/components/CTABanner.astro';
import DifferentiatorSection from '@/components/DifferentiatorSection.astro';
import Hero from '@/components/Hero.astro';
import IndustryCard from '@/components/IndustryCard.astro';
import OperationsGallery from '@/components/OperationsGallery.astro';
import ProcessSteps from '@/components/ProcessSteps.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import UseCaseCard from '@/components/UseCaseCard.astro';
import { operationalImages } from '@/data/media';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { industries } from '@/data/industries';
import { processSteps } from '@/data/process';
import { services } from '@/data/services';
import { siteConfig } from '@/data/site';
import { useCases } from '@/data/useCases';

const featuredServices = services.slice(0, 4);
const featuredIndustries = industries.slice(0, 4);
---

<BaseLayout
  title="Warehouse Work Completed on Demand"
  description="Project-based warehouse operations support for overflow fulfillment, container unloading, kitting, reverse logistics, and backlog cleanup."
>
  <Hero
    eyebrow="Project-based warehouse execution"
    title="On-demand warehouse support for overflow, backlog, and project work."
    description="When containers pile up, orders spike, or projects keep slipping, bring us the work. We scope it, quote it by the job, and get it done without pulling your team off its priorities."
    kicker="Quoted by the job. Built for overflow, backlog, and special projects."
    primaryCta={{ label: 'Get a Job Quote', href: '/request-a-quote' }}
    secondaryCta={{ label: 'See Services', href: '/services' }}
    highlights={siteConfig.heroHighlights}
    panelTitle="Built for work that needs relief"
    panelBody="Bring us a clear warehouse job and we will help you get it done with a clear scope, a clear quote, and a clear next step."
  />

  <Section className="!pt-8 sm:!pt-10 lg:!pt-12 !pb-0">
    <div class="rounded-[1.5rem] border border-charcoal-100 bg-white/80 px-6 py-4 shadow-sm backdrop-blur">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-sm font-medium text-charcoal-900">
          Serving businesses in the <span class="font-semibold text-brand-950">Columbus, Ohio area</span> with project-based warehouse support.
        </p>
        <a href="/contact" class="text-sm font-semibold text-brand-950 hover:text-brand-700">
          Talk through local fit
        </a>
      </div>
    </div>
  </Section>

  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-start">
      <SectionIntro
        eyebrow="What we do"
        title="We take on warehouse work your team cannot absorb right now."
        description="That includes container unloading, fulfillment overflow, kitting, reverse logistics, rework, backlog cleanup, and other warehouse projects that need to get done."
      />
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Why companies call us</p>
        <ul class="mt-5 space-y-4">
          {siteConfig.trustPoints.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
              <span class="text-sm leading-7 text-charcoal-900">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-8 rounded-[1.75rem] border border-charcoal-100 bg-white/80 px-6 py-5 shadow-sm backdrop-blur">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Common jobs we quote</p>
        <div class="flex flex-wrap gap-3 text-sm font-medium text-brand-950">
          <span class="rounded-full bg-mist-100 px-4 py-2">Container unloading</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Overflow orders</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Kitting projects</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Returns processing</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Backlog cleanup</span>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <OperationsGallery images={operationalImages} />
    </div>

    <div class="mt-12 flex items-end justify-between gap-6">
      <SectionIntro
        eyebrow="Core services"
        title="Common types of warehouse work we handle."
        description="Built for overflow, backlog, and project work with a clear need, a clear scope, and a clear finish line."
      />
      <a href="/services" class="btn-secondary hidden lg:inline-flex">
        View All Services
      </a>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
      {featuredServices.map((service) => <ServiceCard service={service} compact />)}
    </div>
    <div class="mt-8 lg:hidden">
      <a href="/services" class="btn-secondary">
        View All Services
      </a>
    </div>
  </Section>

  <Section surface="mist">
    <DifferentiatorSection />
  </Section>

  <Section surface="mist" className="relative overflow-hidden">
    <SectionIntro
      eyebrow="You call us when"
      title="Work is piling up and your team cannot keep taking it on."
      description="This model works best when the need is clear, the pressure is real, and you do not want to pull your team away from the work it already owns."
    />
    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {useCases.map((useCase) => <UseCaseCard useCase={useCase} />)}
    </div>
  </Section>

  <Section className="!pt-14 sm:!pt-16">
    <SectionIntro
      eyebrow="How it works"
      title="Simple to request. Simple to scope. Simple to move forward."
      description="Tell us what needs to get done, we review the scope, we send a quote, and the work moves forward."
    />
    <div class="mt-10">
      <ProcessSteps steps={processSteps} />
    </div>
  </Section>

  <Section className="!pb-14 sm:!pb-16">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <SectionIntro
        eyebrow="Who this works for"
        title="Built for teams under real warehouse pressure."
        description="A strong fit for product businesses dealing with overflow, backlog, and warehouse projects that need to be handled without slowing down the rest of the floor."
      />
      <div class="card-surface p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Best fit for</p>
        <div class="mt-5 space-y-4 text-sm leading-7 text-charcoal-900">
          {siteConfig.qualificationFits.map((item) => <p>{item}</p>)}
        </div>
      </div>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[24rem_minmax(0,1fr)] lg:items-start">
      <div class="card-dark p-8">
        <p class="eyebrow !border-white/15 !bg-white/5 !text-accent-400">Not designed for</p>
        <div class="mt-5 space-y-4 text-sm leading-7 text-white/80">
          {siteConfig.qualificationNotFits.map((item) => <p>{item}</p>)}
        </div>
      </div>
      <div>
        <div class="flex items-end justify-between gap-6">
          <SectionIntro
            eyebrow="Industries"
            title="Common types of businesses we support."
            description="E-commerce brands, retailers, consumer product companies, industrial operations, and growing businesses often run into the same problem: too much warehouse work for the current team to keep absorbing."
          />
          <a href="/industries-served" class="btn-secondary hidden lg:inline-flex">
            Explore Fit
          </a>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {featuredIndustries.map((industry) => <IndustryCard industry={industry} />)}
        </div>
      </div>
    </div>
  </Section>

  <Section>
    <CTABanner
      title="If warehouse work is stacking up, start with the job putting the most pressure on your team."
      description="Send the scope, timeline, and volume. We will review the work and help you move toward a clear next step quickly."
    />
  </Section>
</BaseLayout>
