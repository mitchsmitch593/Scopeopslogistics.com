---
import CTABanner from '@/components/CTABanner.astro';
import Hero from '@/components/Hero.astro';
import ProcessSteps from '@/components/ProcessSteps.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { processSteps } from '@/data/process';
import { siteConfig } from '@/data/site';

const phoneHref = `tel:${siteConfig.contactPhone.replace(/[^\d]/g, '')}`;
const hiddenCosts = [
  'No payroll setup',
  'No workers comp admin',
  'No training lag',
  'No overtime surprises',
  'Less supervisor babysitting',
];
const authorityPoints = [
  {
    title: 'Outcome-based buying',
    description: 'You request a completed warehouse task, not an open-ended block of hours.',
  },
  {
    title: 'Managed execution',
    description: 'ScopeOps provides project leadership for pace, quality, and safety so your supervisors are not stuck managing every detail.',
  },
  {
    title: 'Fast response',
    description: 'Initial response within one business day for most quote requests.',
  },
  {
    title: 'Safety-standard alignment',
    description: 'Work is planned around your facility rules, site expectations, and operating constraints.',
  },
];
const comparisonRows = [
  {
    label: 'Pricing',
    temp: 'Hourly billing that can rise when work moves slowly.',
    scopeops: 'Project-based quotes tied to the workload and timeline.',
  },
  {
    label: 'Management',
    temp: 'Your supervisors often carry the burden of directing the work.',
    scopeops: 'The engagement is organized around the project outcome from the start.',
  },
  {
    label: 'Fit',
    temp: 'Best for general labor coverage.',
    scopeops: 'Best for overflow, backlog, and warehouse work with a defined result.',
  },
];
const homepageServices = [
  {
    title: 'Container Unloading',
    description: 'Clear the dock and protect inbound flow when containers threaten yard space or receiving schedules.',
    trigger: 'Best for inbound surges, delayed freight, and dock congestion.',
    href: '/services/container-unloading',
  },
  {
    title: 'Pick and Pack Overflow',
    description: 'Protect ship times when seasonal spikes or marketing-driven volume push orders past internal capacity.',
    trigger: 'Best for promotions, flash sales, and temporary outbound pressure.',
    href: '/services/pick-and-pack-overflow',
  },
  {
    title: 'Fulfillment Support',
    description: 'Add targeted outbound capacity to clear backlog without rebuilding your permanent labor plan.',
    trigger: 'Best for constrained fulfillment lanes and short-term volume relief.',
    href: '/services/fulfillment-support',
  },
  {
    title: 'Kitting and Assembly',
    description: 'Handle labor-heavy project work like promos, relabeling, launch kits, and light assembly.',
    trigger: 'Best for one-time programs, retailer prep, and special projects.',
    href: '/services/kitting-and-assembly',
  },
];
---

<BaseLayout
  title="Warehouse Work Completed on Demand"
  description="Project-based warehouse operations support for overflow fulfillment, container unloading, kitting, reverse logistics, and backlog cleanup."
>
  <Hero
    eyebrow="Project-based warehouse execution"
    title="Warehouse work completed when your team is at capacity."
    description="Project-based execution for container unloading, fulfillment overflow, and backlog cleanup. We provide coordinated warehouse support so you get results without hiring temporary labor."
    kicker="Fixed-rate project quotes | Managed execution | Safety + insurance review"
    primaryCta={{ label: 'Get a Warehouse Quote', href: '/request-a-quote' }}
    secondaryCta={{ label: 'See Services', href: '/services' }}
    phoneCta={{ label: `Call ${siteConfig.contactPhone}`, href: phoneHref }}
    highlights={siteConfig.heroHighlights}
    panelTitle="Capacity without the staffing drag"
    panelBody="Bring us a defined task or surge in workload. ScopeOps reviews the details, quotes the project, and helps move the bottleneck."
  />

  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-start">
      <SectionIntro
        eyebrow="What we do"
        title="We help warehouse teams clear the work that is slowing everything else down."
        description="Clients call when volume spikes, inbound freight piles up, returns back up, or special projects start taking attention away from the core operation."
      />
      <div class="card-surface p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Why companies call us</p>
        <ul class="mt-5 space-y-4">
          {siteConfig.trustPoints.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
              <span class="text-sm leading-7 text-charcoal-900">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-8 rounded-[1.75rem] border border-charcoal-100 bg-white/80 px-6 py-5 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Common jobs we quote</p>
        <div class="flex flex-wrap gap-3 text-sm font-medium text-brand-950">
          <span class="rounded-full bg-mist-100 px-4 py-2">Container unloading</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Overflow orders</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Kitting projects</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Returns processing</span>
          <span class="rounded-full bg-mist-100 px-4 py-2">Backlog cleanup</span>
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-[1.75rem] bg-brand-950 p-6 text-white shadow-[var(--shadow-panel)]">
      <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-400">Cost avoidance</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight">The hidden costs we eliminate.</h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-white/70">
          Project-based support keeps the focus on the finished workload instead of the administrative drag that often comes with short-term labor.
        </p>
      </div>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {hiddenCosts.map((cost) => (
          <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold">
            <svg class="h-4 w-4 shrink-0 text-accent-400" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.5 8.2 6.6 11.3 12.8 4.7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{cost}</span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section surface="mist">
    <SectionIntro
      eyebrow="Why not staffing"
      title="A cleaner alternative to buying hourly labor."
      description="Temp labor can help in some situations, but warehouse backlogs and defined projects often need a managed path to completion."
    />
    <div class="mt-10 overflow-hidden rounded-[1.75rem] border border-charcoal-100 bg-white shadow-[var(--shadow-panel)]">
      <div class="grid bg-brand-950 px-6 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white md:grid-cols-[12rem_1fr_1fr]">
        <p>Compare</p>
        <p class="mt-3 md:mt-0">The temp agency way</p>
        <p class="mt-3 text-accent-400 md:mt-0">The ScopeOps way</p>
      </div>
      {comparisonRows.map((row) => (
        <div class="grid border-t border-charcoal-100 px-6 py-5 md:grid-cols-[12rem_1fr_1fr]">
          <p class="text-sm font-semibold text-brand-950">{row.label}</p>
          <p class="mt-3 text-sm leading-7 text-charcoal-800 md:mt-0 md:pr-6">{row.temp}</p>
          <p class="mt-3 text-sm font-medium leading-7 text-charcoal-900 md:mt-0">{row.scopeops}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section>
    <div class="flex items-end justify-between gap-6">
      <SectionIntro
        eyebrow="Core services"
        title="Start with the trigger event creating pressure."
        description="The fastest quote requests usually begin with a specific bottleneck: inbound freight, outbound volume, kitting work, or backlog."
      />
      <a href="/services" class="btn-secondary hidden lg:inline-flex">
        View All Services
      </a>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {homepageServices.map((service) => (
        <article class="card-surface p-7">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">Trigger event</p>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-brand-950">{service.title}</h3>
          <p class="mt-4 text-sm leading-7 text-charcoal-800">{service.description}</p>
          <div class="mt-6 rounded-2xl bg-mist-100 p-5">
            <p class="text-sm font-semibold text-brand-950">{service.trigger}</p>
          </div>
          <a href={service.href} class="mt-6 inline-flex text-sm font-semibold text-brand-950 hover:text-accent-500">
            View service
          </a>
        </article>
      ))}
    </div>
    <div class="mt-8 lg:hidden">
      <a href="/services" class="btn-secondary">
        View All Services
      </a>
    </div>
  </Section>

  <Section surface="mist" className="!pt-14 sm:!pt-16">
    <SectionIntro
      eyebrow="Why companies call us"
      title="Built to reduce management drag when warehouse work piles up."
      description="The value is not just extra people. It is a simpler way to move a defined workload without disrupting daily operations."
    />
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {authorityPoints.map((point) => (
        <article class="card-surface p-6">
          <h3 class="text-lg font-semibold tracking-tight text-brand-950">{point.title}</h3>
          <p class="mt-3 text-sm leading-7 text-charcoal-800">{point.description}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section>
    <SectionIntro
      eyebrow="How it works"
      title="No-friction project support."
      description="Share the scope, get project-based pricing, and keep your core team focused while the bottleneck is handled."
    />
    <div class="mt-10">
      <ProcessSteps steps={processSteps} />
    </div>
  </Section>

  <Section>
    <CTABanner
      title="Stop the backlog today."
      description={`Do not let unprocessed returns, outbound spikes, or inbound containers stall your operation. Request a project quote and get an initial response within one business day. Call ${siteConfig.contactPhone} if the need is urgent.`}
      primaryLabel="Request a Project Quote"
      supportText="Most quote requests receive an initial response within one business day."
    />
  </Section>
</BaseLayout>
