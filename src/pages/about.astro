---
import CTABanner from '@/components/CTABanner.astro';
import Hero from '@/components/Hero.astro';
import Section from '@/components/Section.astro';
import SectionIntro from '@/components/SectionIntro.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
---

<BaseLayout
  title="About"
  description="Learn how warehouse work gets completed through clear scope, dependable communication, and job-based support."
>
  <Hero
    eyebrow="About"
    title="A practical warehouse partner built to get work done, relieve pressure, and keep operations moving."
    description="This model is built for warehouse work your team does not have the time or capacity to finish on its own. The role is simple: understand the job, scope it clearly, and get it done."
    primaryCta={{ label: 'Contact Us', href: '/contact' }}
    secondaryCta={{ label: 'Request a Quote', href: '/request-a-quote' }}
    compact
    panelTitle="What we stand for"
    panelBody="Clear scope, dependable communication, and warehouse support that helps you relieve pressure without disrupting your team."
  />

  <Section>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <SectionIntro
        eyebrow="Positioning"
        title="Built to help companies clear warehouse work without slowing down the rest of the floor."
        description="When backlog builds, orders surge, or a project keeps slipping, this model gives you a practical way to get the work done without pulling your team away from the jobs it already owns."
      />
      <div class="card-surface p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-charcoal-800">Core principles</p>
        <ul class="mt-5 space-y-4">
          {siteConfig.aboutPrinciples.map((principle) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
              <span class="text-sm leading-7 text-charcoal-900">{principle}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Section surface="mist">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="card-surface p-7">
        <h2 class="text-xl font-semibold tracking-tight text-brand-950">Execution-focused</h2>
        <p class="mt-4 text-sm leading-7 text-charcoal-800">
          The focus stays on warehouse work that needs to be completed, not vague labor coverage.
        </p>
      </div>
      <div class="card-surface p-7">
        <h2 class="text-xl font-semibold tracking-tight text-brand-950">Dependable</h2>
        <p class="mt-4 text-sm leading-7 text-charcoal-800">
          Clear communication, careful scoping, and realistic expectations shape the way the work gets handled.
        </p>
      </div>
      <div class="card-surface p-7">
        <h2 class="text-xl font-semibold tracking-tight text-brand-950">Built for warehouse reality</h2>
        <p class="mt-4 text-sm leading-7 text-charcoal-800">
          Built for real warehouse use cases like overflow fulfillment, unloading, rework, returns, and backlog cleanup.
        </p>
      </div>
    </div>
  </Section>

  <Section>
    <div class="card-dark p-8 lg:p-10">
      <p class="eyebrow !border-white/15 !bg-white/5 !text-accent-400">How we work</p>
      <h2 class="mt-6 font-serif text-3xl font-medium tracking-tight text-balance sm:text-4xl">
        A practical way to add warehouse capacity when the work is clear and the need is real.
      </h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-white/80">
        If the work is clear, it can be scoped around volume, timing, and site conditions. That gives you a clearer path to getting it done
        and a simpler way to add help without losing control of the job.
      </p>
    </div>
  </Section>

  <Section>
    <CTABanner
      title="Ready to scope a warehouse project or overflow need?"
      description="Use the quote request flow for a clear warehouse job, or contact the team directly if you want to talk it through before requesting a quote."
    />
  </Section>
</BaseLayout>
