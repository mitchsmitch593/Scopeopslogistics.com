---
import type { ProcessStep } from '@/types/content';

interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;
---

<ol class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
  {steps.map((item) => (
    <li class="card-surface h-full p-6">
      <span class="text-xs font-semibold uppercase tracking-[0.24em] text-accent-500">
        Step {item.step}
      </span>
      <h3 class="mt-4 text-xl font-semibold tracking-tight text-brand-950">{item.title}</h3>
      <p class="mt-3 text-sm leading-7 text-charcoal-800">{item.description}</p>
    </li>
  ))}
</ol>
