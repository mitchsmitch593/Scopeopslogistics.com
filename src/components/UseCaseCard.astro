---
import type { UseCase } from '@/types/content';

interface Props {
  useCase: UseCase;
}

const { useCase } = Astro.props;
---

<article class="rounded-[1.5rem] border border-charcoal-100 bg-white p-6 shadow-sm">
  <h3 class="text-xl font-semibold tracking-tight text-brand-950">{useCase.title}</h3>
  <p class="mt-3 text-sm leading-7 text-charcoal-800">{useCase.description}</p>
</article>
