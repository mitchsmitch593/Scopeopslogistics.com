---
import type { MediaAsset } from '@/data/media';

interface Props {
  images: MediaAsset[];
}

const { images } = Astro.props;
const [featured, ...supporting] = images;
---

<div class="grid gap-6 lg:grid-cols-[minmax(0,1.25fr)_0.75fr]">
  <figure class="card-surface group overflow-hidden">
    <img
      src={featured.src}
      alt={featured.alt}
      class="h-80 w-full object-cover transition duration-500 group-hover:scale-[1.02] sm:h-[28rem]"
      loading="eager"
      decoding="async"
      referrerpolicy="no-referrer"
    />
    <figcaption class="px-7 py-6">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">{featured.title}</p>
      <p class="mt-3 text-sm leading-7 text-charcoal-800">{featured.caption}</p>
    </figcaption>
  </figure>

  <div class="grid gap-6">
    {supporting.map((image) => (
      <figure class="card-surface group overflow-hidden">
        <img
          src={image.src}
          alt={image.alt}
          class="h-48 w-full object-cover transition duration-500 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
          referrerpolicy="no-referrer"
        />
        <figcaption class="px-6 py-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-500">{image.title}</p>
          <p class="mt-3 text-sm leading-7 text-charcoal-800">{image.caption}</p>
        </figcaption>
      </figure>
    ))}
  </div>
</div>
