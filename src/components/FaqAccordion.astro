---
import type { FaqItem } from '@/types/content';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const formatAnswer = (answer: string) =>
  answer.replace(/\*\*(.*?)\*\*/g, '<strong class="font-semibold text-brand-950">$1</strong>');
---

<div class="space-y-4">
  {items.map((item) => (
    <details class="card-surface group p-6">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-lg font-semibold tracking-tight text-brand-950">
        <span>{item.question}</span>
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-mist-100 text-brand-950 group-open:rotate-45">
          +
        </span>
      </summary>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-charcoal-800" set:html={formatAnswer(item.answer)} />
      {item.cta && (
        <a href={item.cta.href} class="mt-5 inline-flex text-sm font-semibold text-brand-950 hover:text-accent-500">
          {item.cta.label} →
        </a>
      )}
    </details>
  ))}
</div>
