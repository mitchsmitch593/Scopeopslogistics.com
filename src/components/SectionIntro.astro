---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-5 font-serif text-3xl font-medium tracking-tight text-balance text-brand-950 sm:text-4xl">
    {title}
  </h2>
  <p class="mt-4 text-base leading-7 text-charcoal-800 sm:text-lg">{description}</p>
</div>
