---
import type { Service } from '@/types/content';

interface Props {
  service: Service;
  compact?: boolean;
}

const { service, compact = false } = Astro.props;
---

<article class="card-surface group flex h-full flex-col p-7">
  <div class="flex items-center justify-between gap-4">
    <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-brand-950 text-xs font-semibold uppercase tracking-[0.2em] text-white transition duration-300 group-hover:-translate-y-0.5 group-hover:bg-brand-900">
      {service.title
        .split(' ')
        .slice(0, 2)
        .map((word) => word[0])
        .join('')}
    </span>
    <span class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent-500">
      {service.badge ?? 'Project execution'}
    </span>
  </div>

  <h3 class="mt-6 text-2xl font-semibold tracking-tight text-brand-950">{service.title}</h3>
  <p class="mt-4 text-sm leading-7 text-charcoal-800">{service.summary}</p>

  {!compact && (
    <>
      <div class="mt-6 rounded-2xl bg-mist-100 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-charcoal-800">Trigger</p>
        <p class="mt-3 text-sm leading-7 text-charcoal-900">{service.trigger ?? service.useCases[0]}</p>
      </div>

      <div class="mt-6">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-charcoal-800">Common use cases</p>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-charcoal-900">
          {service.useCases.map((useCase) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-500"></span>
              <span>{useCase}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-6 border-t border-charcoal-100 pt-5">
        <p class="text-sm font-semibold leading-7 text-brand-950">{service.outcome ?? service.benefit}</p>
      </div>
    </>
  )}

  {compact && (
    <p class="mt-5 text-sm leading-7 text-charcoal-800">
      <span class="font-semibold text-brand-950">Benefit:</span> {service.benefit}
    </p>
  )}

  <div class="mt-8 grid gap-3 pt-6">
    <a href="/request-a-quote" class="btn-primary w-full">
      Get a Quote
    </a>
  </div>
</article>
