---
import { navigationItems, primaryCta } from '@/data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<details class="group md:hidden">
  <summary class="flex cursor-pointer list-none items-center gap-3 rounded-full border border-charcoal-200 bg-white px-4 py-2.5 text-sm font-semibold text-charcoal-900 shadow-sm hover:border-brand-900 hover:text-brand-900">
    <span>Menu</span>
    <span class="text-xs text-charcoal-800 group-open:hidden">Open</span>
    <span class="hidden text-xs text-charcoal-800 group-open:inline">Close</span>
  </summary>

  <div class="absolute left-0 right-0 top-full z-40 mt-4 rounded-[1.75rem] border border-charcoal-100 bg-white p-6 shadow-[var(--shadow-panel)]">
    <nav aria-label="Mobile navigation">
      <ul class="space-y-2">
        {navigationItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block rounded-2xl px-4 py-3 text-sm font-medium',
                currentPath === item.href
                  ? 'bg-brand-950 text-white'
                  : 'text-charcoal-900 hover:bg-mist-100 hover:text-brand-900',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href={primaryCta.href} class="btn-primary mt-4 w-full">
      {primaryCta.label}
    </a>
  </div>
</details>
