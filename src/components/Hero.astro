---
interface Cta {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  kicker?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  phoneCta?: Cta;
  highlights?: string[];
  panelTitle?: string;
  panelBody?: string;
  compact?: boolean;
}

const {
  eyebrow,
  title,
  description,
  kicker,
  primaryCta,
  secondaryCta,
  phoneCta,
  highlights = [],
  panelTitle = 'Pay for results, not hours',
  panelBody = 'This model is designed for businesses that need warehouse work completed without treating labor as the product.',
  compact = false,
} = Astro.props;
---

<section class="relative overflow-hidden border-b border-charcoal-100/80">
  <div class="absolute inset-x-0 top-0 -z-10 h-[40rem] bg-[radial-gradient(circle_at_top_right,rgba(209,154,42,0.22),transparent_22%),radial-gradient(circle_at_10%_20%,rgba(18,32,55,0.07),transparent_28%),linear-gradient(180deg,#eef3f8_0%,rgba(255,255,255,0)_78%)]"></div>
  <div class="absolute inset-x-0 top-0 -z-10 h-[34rem] bg-[linear-gradient(120deg,rgba(9,17,29,0.03),transparent_42%,rgba(209,154,42,0.08)_100%)]"></div>
  <div class="container-shell py-18 sm:py-22 lg:py-28">
    <div class:list={['grid items-center gap-12 xl:gap-16', compact ? 'lg:grid-cols-[minmax(0,1fr)_22rem]' : 'lg:grid-cols-[minmax(0,1fr)_30rem]']}>
      <div class="max-w-3xl">
        <p class="eyebrow">{eyebrow}</p>
        <h1 class:list={['mt-6 font-serif font-medium tracking-tight text-balance text-brand-950', compact ? 'text-4xl sm:text-5xl' : 'text-5xl sm:text-6xl']}>
          {title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-charcoal-800 sm:text-xl">{description}</p>
        {kicker && (
          <p class="mt-5 max-w-xl border-l-2 border-accent-500/60 pl-4 text-sm font-semibold uppercase tracking-[0.16em] text-brand-900/75">
            {kicker}
          </p>
        )}
        {(primaryCta || secondaryCta) && (
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            {primaryCta && (
              <a class="btn-primary" href={primaryCta.href}>
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a class="btn-secondary" href={secondaryCta.href}>
                {secondaryCta.label}
              </a>
            )}
          </div>
        )}
        {phoneCta && (
          <a href={phoneCta.href} class="mt-4 inline-flex text-sm font-semibold text-brand-950 hover:text-brand-700 sm:hidden">
            {phoneCta.label}
          </a>
        )}
      </div>

      <div class="card-dark relative overflow-hidden p-8 lg:p-9">
        <div class="absolute inset-0 bg-[linear-gradient(145deg,rgba(255,255,255,0.06),transparent_28%,rgba(209,154,42,0.08)_100%)]"></div>
        <div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-white/30 to-transparent"></div>
        <div class="relative">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-accent-400">Execution model</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight">{panelTitle}</h2>
          <p class="mt-3 text-sm leading-7 text-white/75">{panelBody}</p>
        </div>
        {highlights.length > 0 && (
          <ul class="relative mt-7 space-y-4">
            {highlights.map((highlight) => (
              <li class="flex gap-3">
                <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent-500/15 text-xs font-semibold text-accent-400">
                  +
                </span>
                <span class="text-sm leading-6 text-white/85">{highlight}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>
</section>
