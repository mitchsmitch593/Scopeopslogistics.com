---
import { primaryCta } from '@/data/navigation';
import { siteConfig } from '@/data/site';

const phoneHref = `tel:${siteConfig.contactPhone.replace(/[^\d]/g, '')}`;
---

<div class="fixed inset-x-0 bottom-0 z-50 border-t border-white/15 bg-brand-950/95 px-4 py-3 shadow-[0_-14px_35px_rgba(9,17,29,0.22)] backdrop-blur md:hidden">
  <div class="mx-auto flex max-w-md items-center gap-3">
    <a href={primaryCta.href} class="btn-primary min-h-12 flex-1 !bg-accent-500 !px-4 !text-brand-950 hover:!bg-accent-400">
      {primaryCta.label}
    </a>
    <a href={phoneHref} class="inline-flex min-h-12 items-center justify-center rounded-full bg-white px-4 text-sm font-semibold text-brand-950 shadow-lg shadow-brand-950/20 hover:-translate-y-0.5 hover:bg-mist-100" aria-label={`Call ${siteConfig.contactPhone}`}>
      Call
    </a>
  </div>
</div>
